{
    "routes": [
        {
            "src": "/.*",
            "dest": "/index.html"
        },
        {
            "src": "/api/(.*)",
            "dest": "/backend/api/$1"
        },
        {
            "src": "/old-path",
            "dest": "/new-path",
            "status": 301
        },
        {
            "src": "/(.*)",
            "headers": {
                "Cache-Control": "public, max-age=3600"
            }
        }
    ]
}